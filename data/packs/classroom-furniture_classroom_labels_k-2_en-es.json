  "teacher_notes": {
    "objective": "To support K-2 ELL newcomers in identifying common classroom furniture, understanding daily routines, and adhering to classroom rules through bilingual visual labels.",
    "suggested_use": "Print full-size labels for larger furniture items and walls. Print small-size labels for bins, smaller furniture pieces, or specific areas. Display visual routine cards in a prominent sequence. Post classroom rules at eye level. Encourage students to point to labels as they interact with items or follow routines.",
    "materials_needed": [
      "Printer",
      "Cardstock",
      "Laminator",
      "Scissors",
      "Adhesive (tape, velcro, glue dots)"
    ],
    "differentiation_tips": [
      "Use gestures and repetition when introducing new labels.",
      "Create a scavenger hunt for students to find labeled items.",
      "Pair students for peer support in identifying labels.",
      "Incorporate labels into daily games or activities (e.g., 'Simon Says' using furniture names).",
      "Encourage students to use the L1 and L2 terms."
    ]
  },
