  "teacher_notes": {
    "objective": "To facilitate vocabulary acquisition, promote safety, and establish clear routines in a bilingual science lab setting for young learners.",
    "suggested_use": "Print, laminate, and display labels throughout the science lab. Use full-size labels for general areas and large equipment, and small-size labels for bins and specific tools. Post visual routine cards in sequence near the entrance or a designated routine board. Review rules daily at the start of lab activities.",
    "materials_needed": [
      "Printer",
      "Laminator",
      "Scissors",
      "Adhesive (tape, glue dots, or Velcro)"
    ],
    "differentiation_tips": [
      "Pair labels with real objects (realia) whenever possible.",
      "Encourage students to echo new vocabulary.",
      "Use gestures and TPR (Total Physical Response) to demonstrate meaning.",
      "Create a 'Science Word Wall' to reinforce new terms.",
      "Provide opportunities for students to lead routines using the visual cards."
    ]
  },
