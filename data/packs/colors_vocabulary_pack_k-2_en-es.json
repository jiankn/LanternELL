  "teacher_notes": {
    "objective": "Students will be able to identify and name 12 basic colors in English and Spanish, and associate them with common objects.",
    "suggested_use": "Introduce colors using flashcards and realia. Use the mini-book for shared reading and repeat after me. Worksheets can be used for independent practice, small group work, or as a station activity. Encourage students to point to colors in the classroom.",
    "materials_needed": [
      "Crayons, markers, or colored pencils",
      "Color flashcards (English and Spanish)",
      "Real objects of different colors (e.g., red apple, blue ball, yellow banana)",
      "Scissors (for mini-book assembly)",
      "Glue sticks (for mini-book assembly)"
    ],
    "differentiation_tips": [
      "Support: Provide color cues or physical color swatches for matching. Allow students to work in pairs. Focus on 3-4 colors at a time for initial learning. Use hand-over-hand for tracing if needed.",
      "Challenge: Encourage students to use colors in simple sentences (e.g., 'The car is blue.'). Ask them to identify colors of objects not on the worksheets. Introduce color mixing concepts."
    ]
  },
