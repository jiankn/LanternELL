  "teacher_notes": {
    "objective": "Students will be able to identify and name common animals in English and Spanish. Students will practice tracing and writing animal names, and matching words to pictures.",
    "suggested_use": "Introduce new vocabulary with flashcards or realia. Use the mini-book for shared reading, focusing on repetitive sentence structures. Worksheets can be used for independent practice, small group work, or as homework. Encourage students to use the words in simple sentences.",
    "materials_needed": [
      "Printed vocabulary cards (optional)",
      "Crayons or colored pencils",
      "Pencils",
      "Scissors (for mini-book assembly)",
      "Glue or stapler (for mini-book assembly)"
    ],
    "differentiation_tips": [
      "**Support:** Provide a word bank for matching activities. Use hand-over-hand guidance for tracing. Pair students with a stronger peer for support. Show pictures and say words aloud multiple times.",
      "**Challenge:** Ask students to describe animals using adjectives. Encourage them to draw their favorite animal and write a sentence about it. Have them create their own sentences using the new vocabulary."
    ]
  },
