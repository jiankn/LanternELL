  "teacher_notes": {
    "objective": "To provide a highly visual and interactive environment for K-2 students to learn and practice days of the week, months of the year, and key calendar phrases in both English and Spanish, fostering early biliteracy and routine comprehension.",
    "suggested_use": [
      "Print and laminate full-size labels for a prominent daily calendar display (e.g., 'Today is...', 'The Month is...').",
      "Use small-size month labels on a rotating 'Month of the Year' wheel or a linear display.",
      "Integrate day labels into a daily calendar routine where students physically change the day.",
      "Attach visual routine cards to a daily schedule board, pointing to each as the routine progresses.",
      "Display classroom rules prominently, reviewing them daily or as needed."
    ],
    "materials_needed": [
      "Printer",
      "Laminator (optional, but recommended for durability)",
      "Velcro dots or tape",
      "Wall space or bulletin board",
      "Pointer stick (for calendar time)"
    ],
    "differentiation_tips": [
      "For beginners: Focus on repeating the target vocabulary daily. Use gestures and TPR (Total Physical Response).",
      "For developing learners: Encourage sentence frames (e.g., 'Today is [day].', 'El mes es [month].'). Ask simple questions.",
      "For advanced learners: Have them lead the calendar routine, identify patterns (e.g., days that start with 'M'), or create simple sentences about the day/month."
    ]
  },
