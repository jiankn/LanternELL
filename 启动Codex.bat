@echo off
:: ==============================
:: 1. 解决乱码问题
:: ==============================
:: 将命令行编码强制切换为 UTF-8，解决 "姝..." 这种乱码
chcp 65001 >nul

:: ==============================
:: 2. 配置环境与代理
:: ==============================
:: 设置代理
set HTTP_PROXY=http://127.0.0.1:10808
set HTTPS_PROXY=http://127.0.0.1:10808

:: 设置 Node.js 路径
:: 注意：PATH 必须指向文件夹，所以我去掉了 "node.exe"
set PATH=C:\Program Files\nodejs\;%PATH%

:: ==============================
:: 3. 启动逻辑
:: ==============================
:: 切换到工作目录
cd /d "C:\antigravity\LanternELL"

echo.
echo ==============================================
echo 正在启动 Codex...
echo [配置状态]
echo - 代理端口: 10808
echo - Node路径: C:\Program Files\nodejs\
echo ==============================================
echo.

:: 启动 Codex
call codex

:: 执行完不自动关闭窗口，方便看报错
pause