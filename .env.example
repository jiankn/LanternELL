# ============================================
# LanternELL Environment Variables
# Copy this file to .env.local for development
# ============================================

# ============================================
# AI Provider Configuration
# ============================================

# Primary AI Provider (options: zhipuai, openai)
# Recommended default: zhipuai
AI_ACTIVE_PROVIDER=zhipuai

# Optional fallback provider when the primary provider fails
AI_FALLBACK_PROVIDER=openai

# ZhipuAI (智谱AI) Configuration
# Get your API key from: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
ZHIPUAI_MODEL=glm-4.7
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# OpenAI Configuration (keep as fallback or switch via AI_ACTIVE_PROVIDER)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# Database (Cloudflare D1)
# ============================================

# Local development
DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=

# ============================================
# Stripe Configuration
# ============================================

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ============================================
# Application URLs
# ============================================

# Site URL (required for production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Authentication
# ============================================

# Magic link token duration (in minutes)
AUTH_TOKEN_EXPIRY_MINUTES=20
SESSION_DAYS=30

# ============================================
# Email (Resend)
# ============================================

RESEND_API_KEY=re_your_resend_api_key

# ============================================
# Admin
# ============================================

# Comma-separated admin emails
ADMIN_EMAIL_ALLOWLIST=admin@example.com
