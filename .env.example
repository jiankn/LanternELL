# ============================================
# LanternELL Environment Variables
# Copy this file to .env.local for development
# ============================================

# ============================================
# AI Provider Configuration
# ============================================

# Primary AI Provider (options: zhipuai, openai, deepseek, gemini)
# Recommended default: gemini
AI_ACTIVE_PROVIDER=gemini

# Optional fallback provider when the primary provider fails
AI_FALLBACK_PROVIDER=deepseek

# ZhipuAI (智谱AI) Configuration
# Get your API key from: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
ZHIPUAI_MODEL=glm-4.7
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# OpenAI Configuration (keep as fallback or switch via AI_ACTIVE_PROVIDER)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek Configuration
# Get your API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Gemini Configuration
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ============================================
# Database (Cloudflare D1)
# ============================================

# Local development
DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=

# ============================================
# Stripe Configuration
# ============================================

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ============================================
# Application URLs
# ============================================

# Site URL (required for production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Authentication
# ============================================

# Magic link token duration (in minutes)
AUTH_TOKEN_EXPIRY_MINUTES=20
SESSION_DAYS=30

# ============================================
# Email (Resend)
# ============================================

RESEND_API_KEY=re_your_resend_api_key

# ============================================
# Admin
# ============================================

# Comma-separated admin emails
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# ============================================
# Analytics (optional)
# ============================================

# Plausible Analytics domain (leave empty to disable)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ============================================
# CI/CD (GitHub Actions Secrets)
# ============================================

# CLOUDFLARE_API_TOKEN=  (set in GitHub repo secrets)
# CLOUDFLARE_ACCOUNT_ID= (set in GitHub repo secrets)
